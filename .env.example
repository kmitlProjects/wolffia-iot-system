# MongoDB
# Example without auth:
# MONGO_URI=mongodb://localhost:27017
MONGO_URI=mongodb://username:password@localhost:27017/wolffia?authSource=wolffia&replicaSet=rs0
MONGO_DB=wolffia
MONGO_COLLECTION=sensor_data
IMAGE_ANALYSIS_COLLECTION=daily_image_analysis
DAILY_SUMMARY_COLLECTION=daily_summary
GROW_CYCLE_COLLECTION=grow_cycles
PREDICTION_COLLECTION=prediction_runs
DEBUG_OUTPUT_DIR=/home/pi/Project/data/debug

# MQTT
MQTT_BROKER=localhost
MQTT_PORT=1883
MQTT_TOPIC=pond1/data
MQTT_USERNAME=your-mqtt-username
MQTT_PASSWORD=your-mqtt-password
SENSOR_INTERVAL_SECONDS=3600
LOCAL_API_BASE_URL=http://127.0.0.1:8000
IMAGE_ANALYSIS_REQUEST_TIMEOUT_SECONDS=30

# Camera
CAMERA_DEVICE=/dev/video0
IMAGE_OUTPUT_DIR=/home/pi/Project/data/images
IMAGE_ANALYSIS_SOURCE_MODE=dataset
IMAGE_ANALYSIS_SIMULATION_DIR=/home/pi/Project/test/test_image
IMAGE_ANALYSIS_ARCHIVE_ENABLED=false
IMAGE_ANALYSIS_FORCE_LIGHT_OFF=true
IMAGE_ANALYSIS_LIGHT_SETTLE_SECONDS=2
SNAPSHOT_TIME=09:00
SNAPSHOT_POLL_SECONDS=30
SNAPSHOT_TIMEOUT_SECONDS=15
COVERAGE_H_MIN=35
COVERAGE_H_MAX=95
COVERAGE_S_MIN=40
COVERAGE_V_MIN=40
COVERAGE_VERSION=2026-04-01
# Tune these values so the ROI covers only the water surface.
COVERAGE_ROI_X=54
COVERAGE_ROI_Y=48
COVERAGE_ROI_WIDTH=508
COVERAGE_ROI_HEIGHT=363
COVERAGE_ROI_CORNER_RADIUS=28
COVERAGE_ROI_REFERENCE_WIDTH=640
COVERAGE_ROI_REFERENCE_HEIGHT=480
# Rule-based anomaly watch
ANOMALY_WATCH_ENABLED=true
ANOMALY_WEBHOOK_URL=
ANOMALY_POLL_SECONDS=5
ANOMALY_MIN_AREA_PERCENT=0.9
ANOMALY_FRAME_MIN_AREA_PERCENT=4.0
ANOMALY_PERSIST_FRAMES=1
ANOMALY_COOLDOWN_SECONDS=300
ANOMALY_DIFF_THRESHOLD=14
LIGHT_PIN=19
LIGHT_ACTIVE_LOW=true
PUMP_WATER_PIN=16
PUMP_WATER_ACTIVE_LOW=false
# 1 L / 40 s = 1.5 L/min
WATER_PUMP_FLOW_L_PER_MIN=1.5
# Example for 3 fertilizer relays controlled separately.
PUMP_FERTILIZER_PINS=5,6,13
PUMP_FERTILIZER_ACTIVE_LOW=false
AUTOMATION_COLLECTION=automation_rules
AUTOMATION_POLL_SECONDS=5
APP_TIMEZONE=Asia/Bangkok
DEFAULT_GROW_CYCLE_DAYS=14
PREDICTION_LOOKBACK_DAYS=7
PREDICTION_SENSOR_LIMIT=240
HARVEST_MODEL_ENABLED=true
HARVEST_MODEL_PATH=/home/pi/Project/data/train/harvest_baseline_model_v2.joblib
HARVEST_MODEL_METRICS_PATH=/home/pi/Project/data/train/harvest_baseline_metrics_v2.json
HARVEST_MODEL_DEFAULT_LIGHT_LUX=7500
HARVEST_MODEL_DEFAULT_FERTILIZER_MG_L=100
HARVEST_MODEL_PH_OPTIMAL=6.0

# Web API
CORS_ALLOW_ORIGINS=*
